PORT=3000
HOST=0.0.0.0

NODE_ENV=development

# Firebase (optional — needed for FCM push to wake app when killed)
# Set FIREBASE_SERVICE_ACCOUNT as a JSON string
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}

# API key for server-to-server auth (mobile app sends this in x-api-key header)
API_KEY=development-key

CALL_TIMEOUT=30000
RING_TIMEOUT=45000
